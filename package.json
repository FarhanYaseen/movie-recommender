{
  "name": "movie-recommender",
  "version": "1.0.0",
  "description": "Semantic movie recommender using pgvector + Anthropic embeddings",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "NODE_ENV=development node src/index.js",
    "seed": "node src/scripts/seed.js",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write src/",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f app",
    "docker:seed": "docker compose exec app node src/scripts/seed.js"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "pg": "^8.11.3",
    "swagger-ui-express": "^5.0.0",
    "yamljs": "^0.3.0"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "prettier": "^3.2.5"
  },
  "keywords": [
    "pgvector",
    "embeddings",
    "movie-recommender",
    "vector-search",
    "semantic-search",
    "ai",
    "recommendation-engine",
    "nodejs",
    "postgresql",
    "voyage-ai"
  ],
  "author": "Your Name <your.email@example.com> (https://yourportfolio.com)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/movie-recommender.git"
  },
  "bugs": {
    "url": "https://github.com/yourusername/movie-recommender/issues"
  },
  "homepage": "https://github.com/yourusername/movie-recommender#readme",
  "type": "commonjs",
  "engines": {
    "node": ">=18.0.0"
  }
}
