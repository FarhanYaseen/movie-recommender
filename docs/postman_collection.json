            "url": {
              "raw": "{{baseUrl}}/{{apiVersion}}/movies/recommend?q=romantic love story with bittersweet ending&limit=5",
              "host": ["{{baseUrl}}"],
              "path": ["{{apiVersion}}", "movies", "recommend"],
              "query": [
                {
                  "key": "q",
                  "value": "romantic love story with bittersweet ending"
                },
                {
                  "key": "limit",
                  "value": "5"
                }
              ]
            }
          },
          "response": []
