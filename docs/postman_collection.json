            "url": {
              "raw": "{{baseUrl}}/{{apiVersion}}/movies/recommend?q=scary horror with psychological terror&limit=5",
              "host": ["{{baseUrl}}"],
              "path": ["{{apiVersion}}", "movies", "recommend"],
              "query": [
