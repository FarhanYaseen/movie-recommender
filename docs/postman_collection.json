      ]
    },
    {
      "name": "Legacy Endpoints",
      "item": [
        {
          "name": "[Legacy] Recommend",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/recommend?q=space exploration&limit=3",
              "host": ["{{baseUrl}}"],
              "path": ["recommend"],
              "query": [
                {
                  "key": "q",
                  "value": "space exploration"
                },
                {
                  "key": "limit",
                  "value": "3"
                }
              ]
            },
            "description": "Legacy endpoint (use /api/v1/movies/recommend instead)"
          },
          "response": []
        },
        {
          "name": "[Legacy] Movies",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/movies",
              "host": ["{{baseUrl}}"],
              "path": ["movies"]
            },
            "description": "Legacy endpoint (use /api/v1/movies instead)"
          },
          "response": []
        }
      ]
    }
  ]
}
