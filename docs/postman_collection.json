              "raw": "{{baseUrl}}/{{apiVersion}}/movies/recommend?q=emotional drama about friendship&limit=5",
              "host": ["{{baseUrl}}"],
              "path": ["{{apiVersion}}", "movies", "recommend"],
              "query": [
                {
                  "key": "q",
                  "value": "emotional drama about friendship"
                },
                {
                  "key": "limit",
                  "value": "5"
                }
              ]
            }
          },
          "response": []
